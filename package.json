{
  "name": "neros-presentation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run validate && npm run typecheck && vite build",
    "package:deck": "npm run build && npm run export:pptx",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "validate": "npm run validate:deck && npm run validate:assets",
    "validate:deck": "tsx scripts/validate-deck.ts",
    "validate:assets": "tsx scripts/validate-assets.ts",
    "import:screenshot": "tsx scripts/import-screenshot.ts",
    "export:pptx": "tsx scripts/export-pptx.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
